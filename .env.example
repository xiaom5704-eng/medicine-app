# NVIDIA_API_KEY: Required for NVIDIA AI API calls.
# Get it from: https://build.nvidia.com/explore/discover
# NOTE: Using this key will prioritize NVIDIA API over local Ollama.
NVIDIA_API_KEY="YOUR_NVIDIA_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OLLAMA_API_BASE_URL: The base URL for the Ollama API.
# In Docker, this should be http://ollama-service:11434
OLLAMA_API_BASE_URL="http://localhost:11434"

# GROQ_API_KEY: Your Groq API key (https://console.groq.com/keys)
# Used as a cloud AI fallback when Ollama is unavailable.
# When deployed to cloud (e.g., Render, Cloud Run), Ollama won't be available,
# so Groq provides fast, free-tier inference as the fallback.
GROQ_API_KEY="gsk_your_groq_api_key_here"
